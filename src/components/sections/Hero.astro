---
import { Image } from "astro:assets";
import { basics } from "@cv";
import Email from "@/icons/Email.astro";
import Phone from "@/icons/Phone.astro";
import GitHub from "@/icons/GitHub.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import WordMap from "@/icons/WordMap.astro";

const {
    name,
    position,
    image,
    email,
    phone,
    url,
    location,
    profiles,
} = basics;
const { city, state, country } = location;
const SOCIAL_ICONS: Record<string, any> = {
    GitHub,
    LinkedIn,
};
---

<header class="hero">
    <div class="hero-left">
        <div class="profile-image">
            <Image src={image} alt={name} width={120} height={120} loading="eager" />
        </div>
        <div class="contact-info">
            {email && (
                <a href={`mailto:${email}`} title={email}>
                    <Email /> {email}
                </a>
            )}
            {phone && (
                <a href={`tel:${phone}`} title={phone}>
                    <Phone /> {phone}
                </a>
            )}
            <span class="location">
                <WordMap /> {city}, {state}, {country}
            </span>
            {profiles.map(({ network, username, url }) => {
                const Icon = SOCIAL_ICONS[network];
                return (
                    <a href={url} target="_blank" rel="noopener noreferrer" title={network}>
                        <Icon /> {username}
                    </a>
                );
            })}
        </div>
    </div>
    <div class="hero-right">
        <h1>{name}</h1>
        <h2>{position}</h2>
    </div>
</header>

<style>
    .hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
        padding: 1.5rem 2rem;
        border-bottom: 2px solid var(--color-primary);
    }

    .hero-left {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: flex-start;
    }

    .profile-image {
        width: 120px;
        height: 120px;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid var(--color-border);
    }

    .profile-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .contact-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .contact-info a, .contact-info span {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: var(--color-secondary);
        text-decoration: none;
    }

    .contact-info a:hover {
        color: var(--color-primary);
    }

    .contact-info :global(svg) {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
    }

    .hero-right {
        text-align: right;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .hero-right h1 {
        font-size: 1.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-primary);
    }

    .hero-right h2 {
        font-size: 1rem;
        font-weight: 500;
        color: var(--color-secondary);
    }

    @media screen and (max-width: 640px) {
        .hero {
            flex-direction: column-reverse;
            align-items: center;
            text-align: center;
            gap: 1rem;
        }

        .hero-left {
            align-items: center;
        }

        .hero-right {
            text-align: center;
        }

        .hero-right h1 {
            font-size: 1.5rem;
        }

        .contact-info {
            align-items: center;
        }
    }
</style>