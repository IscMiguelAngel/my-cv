---
import { certificates } from '@cv'
import { formatDate } from '@/js/Functions'
---

<section class="certificates">
    <h2 class="section-title">CERTIFICACIONES</h2>
    <ul class="certificates-list">
    {
        certificates.map(({ name, date, issuer, certificate, url }) => {
            return (
                <li class="certificate-item">
                    <div class="item-header">
                        <h3>
                            {url !== "" ? <a href={url} target="_blank" rel="noopener noreferrer">{name}</a> : name}
                        </h3>
                        <time>{formatDate(date, false, true)}</time>
                    </div>
                    <p class="issuer">{issuer}</p>
                    {certificate && <p class="certificate-id">Certificado: {certificate}</p>}
                </li>
            )
        })
    }
    </ul>
</section>

<style>
    .certificates {
        padding: 1.5rem 2rem;
    }

    .section-title {
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-primary);
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    .certificates-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .certificate-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .item-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .item-header h3 {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-primary);
        margin: 0;
    }

    .item-header h3 a {
        text-decoration: none;
    }

    .item-header h3 a:hover {
        text-decoration: underline;
    }

    .item-header time {
        font-size: 0.75rem;
        color: var(--color-muted);
        white-space: nowrap;
    }

    .issuer {
        font-size: 0.8rem;
        color: var(--color-secondary);
    }

    .certificate-id {
        font-size: 0.75rem;
        color: var(--color-muted);
    }

    @media screen and (max-width: 640px) {
        .item-header {
            flex-direction: column;
            gap: 0.25rem;
        }

        .item-header time {
            order: -1;
        }
    }
</style>